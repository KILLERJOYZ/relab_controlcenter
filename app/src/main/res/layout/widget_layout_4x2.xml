<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- RAM Box -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.2"
        android:background="@drawable/widget_inner_bg"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:layout_marginEnd="6dp"
        android:padding="10dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bộ nhớ RAM"
            android:textColor="#88FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/ram_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.0 / 0.0 GB"
            android:textColor="#4385f4"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />
        <ProgressBar
            android:id="@+id/ram_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:max="100"
            android:progress="0"
            android:layout_marginTop="6dp" />
    </LinearLayout>

    <!-- CPU/GPU Box -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.5"
        android:background="@drawable/widget_inner_bg"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:layout_marginHorizontal="3dp"
        android:padding="10dp">
        
        <!-- CPU Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CPU:"
                android:textColor="#88FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/cpu_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="#4CAF50"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp" />
        </LinearLayout>
        <ProgressBar
            android:id="@+id/cpu_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:max="100"
            android:progress="0"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="6dp" />

        <!-- GPU Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPU:"
                android:textColor="#88FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/gpu_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="#FF03DAC5"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp" />
        </LinearLayout>
        <ProgressBar
            android:id="@+id/gpu_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:max="100"
            android:progress="0"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Battery Box -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.2"
        android:background="@drawable/widget_inner_bg"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:layout_marginStart="6dp"
        android:padding="10dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trạng thái Pin"
            android:textColor="#88FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/bat_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textColor="#FFBB86FC"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />
        <ProgressBar
            android:id="@+id/bat_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:max="100"
            android:progress="0"
            android:layout_marginTop="6dp" />
    </LinearLayout>
</LinearLayout>
