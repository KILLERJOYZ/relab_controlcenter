<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Relab Control Center"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />
        <TextView
            android:id="@+id/widget_update_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Uptime: 0h 0m"
            android:textColor="#88FFFFFF"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Content Layout (Grid-like columns) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Row 1: CPU & RAM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <!-- CPU -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/widget_inner_bg"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginEnd="4dp"
                android:padding="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bộ xử lý CPU"
                    android:textColor="#88FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/cpu_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
                <ProgressBar
                    android:id="@+id/cpu_progress"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:max="100"
                    android:progress="0"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- RAM -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/widget_inner_bg"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="4dp"
                android:padding="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bộ nhớ RAM"
                    android:textColor="#88FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/ram_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0 / 0.0 GB"
                    android:textColor="#4385f4"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
                <ProgressBar
                    android:id="@+id/ram_progress"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:max="100"
                    android:progress="0"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2: GPU & Storage -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <!-- GPU -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/widget_inner_bg"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginEnd="4dp"
                android:padding="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đồ hoạ GPU"
                    android:textColor="#88FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/gpu_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#FF03DAC5"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
                <ProgressBar
                    android:id="@+id/gpu_progress"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:max="100"
                    android:progress="0"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- Storage -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/widget_inner_bg"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="4dp"
                android:padding="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bộ nhớ trong"
                    android:textColor="#88FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/storage_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0 / 0.0 GB"
                    android:textColor="#FFBB86FC"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
                <ProgressBar
                    android:id="@+id/storage_progress"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:max="100"
                    android:progress="0"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 3: Battery & Network info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Battery -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/widget_inner_bg"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginEnd="4dp"
                android:padding="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thông tin Pin"
                    android:textColor="#88FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/bat_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#FF8A80"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
                <ProgressBar
                    android:id="@+id/bat_progress"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:max="100"
                    android:progress="0"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- Network Speeds -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/widget_inner_bg"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="4dp"
                android:padding="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tải xuống / Tải lên"
                    android:textColor="#88FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold" />
                
                <TextView
                    android:id="@+id/dl_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↓ 0 B/s"
                    android:textColor="#42A5F5"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
                
                <TextView
                    android:id="@+id/ul_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ 0 B/s"
                    android:textColor="#66BB6A"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Footer Network Standard / Wifi SSD -->
    <TextView
        android:id="@+id/wifi_ssid_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Wi-Fi: Đang kết nối..."
        android:textColor="#55FFFFFF"
        android:textSize="10sp"
        android:layout_marginTop="10dp"
        android:gravity="center_horizontal" />
</LinearLayout>
